const app = initializeApp(firebaseConfig);
const database = getDatabase(app);

window.submitAllFeedback = function(){

    let branch = document.getElementById("branch").value;
    let section = document.getElementById("section").value;

    if(branch === "" || section === ""){
        alert("Select Branch and Section ");
        return;
    }

    let feedbackList = [];

    document.querySelectorAll(".subject-box").forEach(box=>{
        let subject = box.querySelector("h3").innerText;
        let rating = box.querySelector(".rating").value;

        if(rating === ""){
            alert("Select rating for all subjects ");
            feedbackList = [];
            return;
        }

        feedbackList.push({
            subject: subject,
            rating: rating
        });
    });

    if(feedbackList.length === 0) return;

    push(ref(database,"feedbacks"),{
        branch: branch,
        section: section,
        feedbacks: feedbackList,
        timestamp: new Date().toISOString()
    });

    alert("Feedback Submitted ");

    document.querySelectorAll(".rating").forEach(r=>r.value="");
}
